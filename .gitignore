# HuggingFace / sentence-transformers local cache
.cache/
huggingface/

# NLTK downloaded corpora (re-downloaded on first run)
nltk_data/

# pip stray files (e.g. from `pip install =2.1` typos)
=*

# Claude Code local settings (machine-specific)
.claude/settings.local.json
.claude/scheduled_tasks.lock

# Anchor embedding cache (regenerated on first import of pipeline.py)
maven_app/anchors/_cache/

# UI mockup templates (local design artifacts)
MAVEN_UI_templates/

# Email attachments / personal files
perinatal_knowledge_base/Fw_*
